#!/bin/zsh
set -euo pipefail

usage() {
  print -u2 "Usage: o [file-or-folder]"
  print -u2
  print -u2 "Environment overrides:"
  print -u2 "  O_IDE_APP='Antigravity'       macOS app name to open with"
  print -u2 "  O_IDE_CMD='code'              CLI command to open with"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if (( $# > 1 )); then
  usage
  exit 64
fi

target="${1:-.}"

if [[ ! -e "$target" ]]; then
  print -u2 "o: path does not exist: $target"
  exit 66
fi

target="${target:A}"

if [[ -n "${O_IDE_CMD:-}" ]]; then
  if command "$O_IDE_CMD" "$target"; then
    print "✅ 已用 ${O_IDE_CMD} 打开: $target"
    exit 0
  else
    rc=$?
    exit "$rc"
  fi
fi

if [[ -n "${O_IDE_APP:-}" ]]; then
  if open -a "$O_IDE_APP" "$target"; then
    print "✅ 已用 ${O_IDE_APP} 打开: $target"
    exit 0
  else
    rc=$?
    exit "$rc"
  fi
fi

app_exists() {
  local app="$1"
  [[ -d "/Applications/${app}.app" || -d "$HOME/Applications/${app}.app" ]]
}

for app in \
  "Antigravity" \
  "Cursor" \
  "Visual Studio Code" \
  "Zed" \
  "Windsurf" \
  "Trae" \
  "IntelliJ IDEA"; do
  if app_exists "$app"; then
    if open -a "$app" "$target"; then
      print "✅ 已用 ${app} 打开: $target"
      exit 0
    else
      rc=$?
      exit "$rc"
    fi
  fi
done

if open "$target"; then
  print "⚠️ 没找到默认 IDE，已用 macOS 默认应用打开: $target"
  exit 0
else
  rc=$?
  exit "$rc"
fi
