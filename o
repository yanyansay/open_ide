#!/bin/zsh
set -euo pipefail

usage() {
  print -u2 "Usage: o [file-or-folder]"
  print -u2
  print -u2 "Environment overrides:"
  print -u2 "  O_IDE_APP='Antigravity IDE'   macOS app name or .app path to open with"
  print -u2 "  O_IDE_CMD='code'              CLI command to open with"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if (( $# > 1 )); then
  usage
  exit 64
fi

target="${1:-.}"

if [[ ! -e "$target" ]]; then
  print -u2 "o: path does not exist: $target"
  exit 66
fi

target="${target:A}"

if [[ -n "${O_IDE_CMD:-}" ]]; then
  if command "$O_IDE_CMD" "$target"; then
    print "✅ 已用 ${O_IDE_CMD} 打开: $target"
    exit 0
  else
    rc=$?
    exit "$rc"
  fi
fi

open_with_app() {
  local app="$1"
  local app_path=""

  if [[ -d "$app" ]]; then
    app_path="$app"
  elif [[ -d "/Applications/${app}.app" ]]; then
    app_path="/Applications/${app}.app"
  elif [[ -d "$HOME/Applications/${app}.app" ]]; then
    app_path="$HOME/Applications/${app}.app"
  fi

  if [[ -n "$app_path" ]]; then
    open -a "$app_path" "$target"
  else
    open -a "$app" "$target"
  fi
}

if [[ -n "${O_IDE_APP:-}" ]]; then
  if open_with_app "$O_IDE_APP"; then
    print "✅ 已用 ${O_IDE_APP} 打开: $target"
    exit 0
  else
    rc=$?
    exit "$rc"
  fi
fi

for app in \
  "Antigravity IDE" \
  "Antigravity" \
  "Cursor" \
  "Visual Studio Code" \
  "Zed" \
  "Windsurf" \
  "Trae" \
  "IntelliJ IDEA"; do
  if open_with_app "$app" 2>/dev/null; then
    print "✅ 已用 ${app} 打开: $target"
    exit 0
  fi
done

if open "$target"; then
  print "⚠️ 没找到默认 IDE，已用 macOS 默认应用打开: $target"
  exit 0
else
  rc=$?
  exit "$rc"
fi
